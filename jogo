<script>
    const FULL_PALETTE = [
        "#000000","#ffffff","#808080","#ff0000",
        "#ff6600","#ffff00","#00ff00","#009900",
        "#00ffff","#0000ff","#aa33ff","#ff00ff",
        "#ff99cc","#663300"
    ];

    let username = "", roomName = "", mqttClient = null, baseTopic = "";
    const listaJogadores = new Set();
    const scores = {};
    let isDrawer = false, currentWord = "", currentDrawerName = "";
    let roundActive = false, currentDrawerIndex = -1;
    let countdownInterval = null, nextRoundTimeout = null, currentTimeLeft = 0;
    const TEMPO_RODADA = 60;
    let eggCooldown = false, flowerCooldown = false;
    let customWords = [];
    let gameEnded = false;
    const PONTUACAO_MAXIMA = 1000;
    
    const PALAVRAS_PADRAO = ["Algema","Chicote","Cama de Casal","Gelatina","Berinjela","Melancia","Morango","Banana","Pepino","Creme","Calcinha","CuecaBoxer","Massagem","Censura","Sutiã","Coração","Vela","Espelho","Pegada","Gemido","Beijo Grego","Chantilly","Travesseiro","Algemas"];
    function getPalavras() { return customWords.length > 0 ? customWords : PALAVRAS_PADRAO; }

    async function salvarPalavras() {
        try {
            await window.storage.set("words:" + roomName, JSON.stringify(customWords), true);
        } catch(e) { console.warn("Storage save error:", e); }
    }

    async function carregarPalavrasSalvas() {
        try {
            const result = await window.storage.get("words:" + roomName, true);
            if (result && result.value) {
                const salvas = JSON.parse(result.value);
                if (Array.isArray(salvas) && salvas.length > 0) {
                    salvas.forEach(w => { if (!customWords.includes(w)) customWords.push(w); });
                    addSystemMessage("💾 " + customWords.length + " fantasias secretas carregadas do histórico do quarto!");
                }
            }
        } catch(e) { }
    }

    let currentTool = 'brush';
    let currentShape = 'free';
    let currentColor = '#000000';
    let currentBrushSize = 2;
    let startX = 0, startY = 0;
    let snapshot = null;
    let lastFormCoordinates = null;

    function toggleWordsPanel() {
        const panel = document.getElementById('words-management-panel');
        panel.style.display = panel.style.display === 'flex' ? 'none' : 'flex';
    }

    function submitRuntimeWords() {
        const textarea = document.getElementById('runtime-new-words');
        const content = textarea.value.trim();
        if (!content || !mqttClient || gameEnded) return;
        const newWordsArr = content.split(',').map(w => w.trim()).filter(w => w.length > 0);
        if (newWordsArr.length > 0) {
            mqttClient.publish(baseTopic + "/customwords/add", JSON.stringify({ words: newWordsArr, sender: username }));
            textarea.value = "";
            toggleWordsPanel();
        }
    }

    function setTool(tool) {
        if (gameEnded) return;
        currentTool = tool;
        document.querySelectorAll('#tools .tool-btn[id^="tool-"]').forEach(b => b.classList.remove('active'));
        document.getElementById('tool-' + tool).classList.add('active');
        const c = document.getElementById('canvas');
        c.className = '';
        if (tool === 'eraser') { c.classList.add('cursor-eraser'); setShape('free'); }
        else if (tool === 'fill') { c.classList.add('cursor-fill'); }
        else { document.getElementById('shape-' + currentShape).classList.add('active'); }
        document.getElementById('fill-status').style.display = tool === 'fill' ? 'block' : 'none';
    }

    function setShape(shape) {
        if (gameEnded) return;
        currentShape = shape;
        document.querySelectorAll('#tools .tool-btn[id^="shape-"]').forEach(b => b.classList.remove('active'));
        document.getElementById('shape-' + shape).classList.add('active');
        if (currentTool === 'fill') setTool('brush');
    }

    function setBrushSize(size, el) {
        currentBrushSize = size;
        document.querySelectorAll('.size-btn').forEach(b => b.classList.remove('active'));
        el.classList.add('active');
        ctx.lineWidth = size;
    }

    function setActiveColor(hex) {
        currentColor = hex;
        document.getElementById('current-color-display').style.background = hex;
        document.getElementById('current-color-display-palette').style.background = hex;
        document.getElementById('color-custom').value = hex;
        document.querySelectorAll('.color-swatch').forEach(s => {
            s.classList.toggle('active', s.dataset.color === hex);
        });
    }

    function pickCustomColor(input) {
        setActiveColor(input.value);
        if (currentTool === 'eraser') setTool('brush');
    }

    function buildPalette() {
        const grid = document.getElementById('palette-grid');
        grid.innerHTML = "";
        FULL_PALETTE.forEach(hex => {
            const swatch = document.createElement('div');
            swatch.className = 'color-swatch';
            swatch.dataset.color = hex;
            swatch.style.background = hex;
            swatch.title = hex;
            if (hex === currentColor) swatch.classList.add('active');
            swatch.addEventListener('click', () => {
                setActiveColor(hex);
                if (currentTool === 'eraser') setTool('brush');
            });
            grid.appendChild(swatch);
        });
    }
    buildPalette();

    const canvas = document.getElementById('canvas');
    const ctx = canvas.getContext('2d');
    let drawing = false;
    const VIRTUAL_WIDTH = 800, VIRTUAL_HEIGHT = 600;

    function ajustarAlturaJanela() { document.body.style.height = window.innerHeight + "px"; }
    window.addEventListener('resize', ajustarAlturaJanela);
    window.addEventListener('load', ajustarAlturaJanela);
    ajustarAlturaJanela();

    function calcPoints(timeLeft) {
        let pts = Math.ceil((timeLeft / TEMPO_RODADA) * 10);
        return Math.max(1, Math.min(10, pts));
    }

    function initCanvasResolution() {
        canvas.width = VIRTUAL_WIDTH; canvas.height = VIRTUAL_HEIGHT;
        ctx.lineCap = 'round'; ctx.lineJoin = 'round'; ctx.lineWidth = currentBrushSize;
    }
    initCanvasResolution();

    function getCanvasCoordinates(clientX, clientY) {
        const rect = canvas.getBoundingClientRect();
        return {
            x: ((clientX - rect.left) / rect.width) * canvas.width,
            y: ((clientY - rect.top) / rect.height) * canvas.height
        };
    }

    canvas.addEventListener('mousedown', (e) => {
        if (!isDrawer || !roundActive || gameEnded) return;
        e.preventDefault();
        const c = getCanvasCoordinates(e.clientX, e.clientY);
        if (currentTool === 'fill') { doFill(Math.round(c.x), Math.round(c.y)); return; }
        onStartDrag(c.x, c.y);
    });
    canvas.addEventListener('mousemove', (e) => {
        if (!drawing || gameEnded) return;
        e.preventDefault();
        const c = getCanvasCoordinates(e.clientX, e.clientY);
        onMoveDrag(c.x, c.y);
    });
    canvas.addEventListener('mouseup', (e) => { e.preventDefault(); onStopDrag(); });
    canvas.addEventListener('mouseleave', (e) => { if (drawing) onStopDrag(); });

    canvas.addEventListener('touchstart', (e) => {
        if (!isDrawer || !roundActive || gameEnded) return;
        e.preventDefault();
        if (e.touches.length !== 1) return;
        const touch = e.touches[0];
        const c = getCanvasCoordinates(touch.clientX, touch.clientY);
        if (currentTool === 'fill') { doFill(Math.round(c.x), Math.round(c.y)); return; }
        onStartDrag(c.x, c.y);
    }, { passive: false });

    canvas.addEventListener('touchmove', (e) => {
        if (!drawing || gameEnded) return;
        e.preventDefault();
        if (e.touches.length !== 1) return;
        const touch = e.touches[0];
        const c = getCanvasCoordinates(touch.clientX, touch.clientY);
        onMoveDrag(c.x, c.y);
    }, { passive: false });

    canvas.addEventListener('touchend', (e) => {
        e.preventDefault();
        onStopDrag();
    }, { passive: false });

    canvas.addEventListener('touchcancel', (e) => {
        e.preventDefault();
        onStopDrag();
    }, { passive: false });

    function onStartDrag(x, y) {
        drawing = true;
        startX = x; startY = y;
        const col = currentTool === 'eraser' ? '#ffffff' : currentColor;
        ctx.fillStyle = col; ctx.strokeStyle = col; ctx.lineWidth = currentBrushSize;
        if (currentShape === 'free') {
            ctx.beginPath(); ctx.moveTo(x, y);
            sendDrawData('start', x, y, col, currentBrushSize);
        } else {
            snapshot = ctx.getImageData(0, 0, canvas.width, canvas.height);
        }
    }

    function onMoveDrag(x, y) {
        if (!drawing) return;
        const col = currentTool === 'eraser' ? '#ffffff' : currentColor;
        ctx.lineWidth = currentBrushSize;
        if (currentShape === 'free') {
            ctx.lineTo(x, y); ctx.stroke();
            sendDrawData('draw', x, y, col, currentBrushSize);
        } else if (currentShape === 'spray') {
            generateSpray(x, y, col, currentBrushSize);
            sendDrawData('spray', x, y, col, currentBrushSize);
        } else {
            if (snapshot) ctx.putImageData(snapshot, 0, 0);
            drawBoundingShape(currentShape, startX, startY, x, y, col, currentBrushSize);
        }
    }

    function onStopDrag() {
        if (!drawing) return;
        drawing = false;
        if (currentShape !== 'free' && currentShape !== 'spray') {
            const lastEvent = lastFormCoordinates;
            if (lastEvent) {
                const col = currentTool === 'eraser' ? '#ffffff' : currentColor;
                sendDrawData('final_shape', lastEvent.sX, lastEvent.sY, col, currentBrushSize, currentShape, lastEvent.cX, lastEvent.cY);
            }
        }
        snapshot = null; lastFormCoordinates = null;
    }

    function drawBoundingShape(shape, sX, sY, cX, cY, color, size) {
        ctx.strokeStyle = color; ctx.fillStyle = "transparent"; ctx.lineWidth = size;
        lastFormCoordinates = { shape, sX, sY, cX, cY };
        ctx.beginPath();
        if (shape === 'square') {
            ctx.strokeRect(sX, sY, cX - sX, cY - sY);
        } else if (shape === 'circle') {
            let rx = (cX - sX) / 2; let ry = (cY - sY) / 2;
            let cx = sX + rx; let cy = sY + ry;
            ctx.save(); ctx.translate(cx, cy); ctx.scale(Math.abs(rx), Math.abs(ry)); ctx.arc(0, 0, 1, 0, 2 * Math.PI); ctx.restore(); ctx.stroke();
        } else if (shape === 'triangle') {
            ctx.moveTo(sX + (cX - sX) / 2, sY); ctx.lineTo(cX, cY); ctx.lineTo(sX, cY); ctx.closePath(); ctx.stroke();
        }
    }

    function generateSpray(x, y, color, size) {
        ctx.fillStyle = color;
        const density = size * 4;
        for (let i = 0; i < density; i++) {
            const angle = Math.random() * Math.PI * 2;
            const radius = Math.random() * (size * 3);
            ctx.fillRect(x + Math.cos(angle) * radius, y + Math.sin(angle) * radius, 1, 1);
        }
    }

    function doFill(startX, startY) {
        if (!isDrawer || !roundActive || gameEnded) return;
        const fillColor = currentColor;
        const imageData = ctx.getImageData(0, 0, canvas.width, canvas.height);
        const data = imageData.data;
        const idx = (startY * canvas.width + startX) * 4;
        const targetR = data[idx], targetG = data[idx+1], targetB = data[idx+2], targetA = data[idx+3];
        const fillR = parseInt(fillColor.slice(1,3),16), fillG = parseInt(fillColor.slice(3,5),16), fillB = parseInt(fillColor.slice(5,7),16);
        if (targetR === fillR && targetG === fillG && targetB === fillB) return;
        const stack = [[startX, startY]];
        const visited = new Uint8Array(canvas.width * canvas.height);
        function match(i) { return Math.abs(data[i]-targetR)<32 && Math.abs(data[i+1]-targetG)<32 && Math.abs(data[i+2]-targetB)<32 && Math.abs(data[i+3]-targetA)<32; }
        while (stack.length) {
            const [x, y] = stack.pop();
            if (x < 0 || x >= canvas.width || y < 0 || y >= canvas.height) continue;
            const vi = y * canvas.width + x;
            if (visited[vi]) continue;
            const pi = vi * 4;
            if (!match(pi)) continue;
            visited[vi] = 1;
            data[pi] = fillR; data[pi+1] = fillG; data[pi+2] = fillB; data[pi+3] = 255;
            stack.push([x+1,y],[x-1,y],[x,y+1],[x,y-1]);
        }
        ctx.putImageData(imageData, 0, 0);
        sendDrawData('fill', startX, startY, fillColor, 0);
    }

    function renderRemoteDraw(data) {
        ctx.strokeStyle = data.color; ctx.fillStyle = data.color; ctx.lineWidth = data.size || 2;
        if (data.action === 'start') { ctx.beginPath(); ctx.moveTo(data.x, data.y); }
        else if (data.action === 'draw') { ctx.lineTo(data.x, data.y); ctx.stroke(); }
        else if (data.action === 'spray') { generateSpray(data.x, data.y, data.color, data.size); }
        else if (data.action === 'clear') { ctx.clearRect(0, 0, canvas.width, canvas.height); }
        else if (data.action === 'fill') { doRemoteFill(Math.round(data.x), Math.round(data.y), data.color); }
        else if (data.action === 'final_shape') {
            ctx.fillStyle = "transparent"; ctx.beginPath();
            if (data.shapeType === 'square') { ctx.strokeRect(data.x, data.y, data.endX - data.x, data.endY - data.y); }
            else if (data.shapeType === 'circle') {
                let rx = (data.endX - data.x) / 2; let ry = (data.endY - data.y) / 2;
                let cx = data.x + rx; let cy = data.y + ry;
                ctx.save(); ctx.translate(cx, cy); ctx.scale(Math.abs(rx), Math.abs(ry)); ctx.arc(0, 0, 1, 0, 2 * Math.PI); ctx.restore(); ctx.stroke();
            } else if (data.shapeType === 'triangle') {
                ctx.moveTo(data.x + (data.endX - data.x) / 2, data.y); ctx.lineTo(data.endX, data.endY); ctx.lineTo(data.x, data.endY); ctx.closePath(); ctx.stroke();
            }
        }
    }

    function doRemoteFill(startX, startY, fillColor) {
        const imageData = ctx.getImageData(0, 0, canvas.width, canvas.height);
        const data = imageData.data;
        const idx = (startY * canvas.width + startX) * 4;
        const targetR = data[idx], targetG = data[idx+1], targetB = data[idx+2], targetA = data[idx+3];
        const fillR = parseInt(fillColor.slice(1,3),16), fillG = parseInt(fillColor.slice(3,5),16), fillB = parseInt(fillColor.slice(5,7),16);
        if (targetR === fillR && targetG === fillG && targetB === fillB) return;
        const stack = [[startX, startY]];
        const visited = new Uint8Array(canvas.width * canvas.height);
        function match(i) { return Math.abs(data[i]-targetR)<32 && Math.abs(data[i+1]-targetG)<32 && Math.abs(data[i+2]-targetB)<32 && Math.abs(data[i+3]-targetA)<32; }
        while (stack.length) {
            const [x, y] = stack.pop();
            if (x < 0 || x >= canvas.width || y < 0 || y >= canvas.height) continue;
            const vi = y * canvas.width + x;
            if (visited[vi]) continue;
            const pi = vi * 4;
            if (!match(pi)) continue;
            visited[vi] = 1;
            data[pi] = fillR; data[pi+1] = fillG; data[pi+2] = fillB; data[pi+3] = 255;
            stack.push([x+1,y],[x-1,y],[x,y+1],[x,y-1]);
        }
        ctx.putImageData(imageData, 0, 0);
    }

    function renderScoreboard() {
        const container = document.getElementById('players-list');
        if (!container) return;
        container.innerHTML = "";
        const sortedPlayers = Array.from(listaJogadores).sort((a, b) => (scores[b] || 0) - (scores[a] || 0));
        sortedPlayers.forEach((nome, index) => {
            const rank = index + 1;
            let rankLabel = rank + "º";
            if (rank === 1) rankLabel = "👑 1º";
            else if (rank === 2) rankLabel = "💋 2º";
            else if (rank === 3) rankLabel = "🍆 3º";
            const item = document.createElement('div');
            item.className = "player-item";
            item.id = "p-" + nome.replace(/\s+/g,'-');
            if (nome === currentDrawerName) item.classList.add('drawing');
            const infoDiv = document.createElement('div'); infoDiv.className = 'player-info';
            const rankSpan = document.createElement('span'); rankSpan.className = 'player-rank'; rankSpan.textContent = rankLabel;
            const nameSpan = document.createElement('span'); nameSpan.className = 'player-name'; nameSpan.textContent = nome;
            infoDiv.appendChild(rankSpan); infoDiv.appendChild(nameSpan);
            const scoreSpan = document.createElement('span'); scoreSpan.className = 'player-score'; scoreSpan.textContent = scores[nome] || 0;
            item.appendChild(infoDiv); item.appendChild(scoreSpan);
            container.appendChild(item);
        });
    }

    function checkEndGameConditions() {
        for (const [jogador, pontuacao] of Object.entries(scores)) {
            if (pontuacao >= PONTUACAO_MAXIMA) {
                triggerVictory(jogador);
                return true;
            }
        }
        return false;
    }

    function triggerVictory(vencedor) {
        gameEnded = true;
        roundActive = false;
        clearInterval(countdownInterval);
        clearTimeout(nextRoundTimeout);
        
        document.getElementById('btn-egg').style.display = 'none';
        document.getElementById('btn-flower').style.display = 'none';
        document.getElementById('btn-skip').style.display = 'none';
        
        document.getElementById('word-display').innerText = `👑 FIM DO ORGIAZO! O DONO DA NOITE É ${vencedor.toUpperCase()}!`;
        document.getElementById('timer-display').innerText = "⏱️ Fim";
        
        showGarticAnnouncement("👑 DEU MATCH SUPREMO!", `${vencedor} atingiu a marca erótica de ${scores[vencedor]} orgasmos/pontos e dominou o quarto! 🎉`);
        addSystemMessage(`👑 PARTIDA CONCLUÍDA! O(A) maior mestre da sedução da sala é: ${vencedor} com ${scores[vencedor]} pontos!`);
        createPetalShower();
    }

    function addScore(nome, pts) {
        if (gameEnded) return;
        if (!scores[nome]) scores[nome] = 0;
        scores[nome] += pts;
        renderScoreboard();
        const el = document.getElementById("p-" + nome.replace(/\s+/g,'-'));
        if (el) {
            const scoreEl = el.querySelector('.player-score');
            if (scoreEl) { scoreEl.classList.add('bump'); setTimeout(() => scoreEl.classList.remove('bump'), 350); }
        }
    }

    function showGarticAnnouncement(title, desc) {
        const box = document.getElementById('round-announcement');
        document.getElementById('announcement-title').innerText = title;
        document.getElementById('announcement-desc').innerText = desc;
        box.classList.add('show');
        setTimeout(() => { box.classList.remove('show'); }, 3200);
    }

    function showScorePopup(pts, nome) {
        const playerEl = document.getElementById("p-" + nome.replace(/\s+/g,'-'));
        if (!playerEl) return;
        const rect = playerEl.getBoundingClientRect();
        const popup = document.createElement('div');
        popup.className = 'score-popup';
        popup.textContent = '+' + pts + ' pts';
        popup.style.left = (rect.left + rect.width/2 - 30) + 'px';
        popup.style.top  = (rect.top - 10) + 'px';
        document.body.appendChild(popup);
        setTimeout(() => popup.remove(), 1500);
    }

    function throwInteractItem(itemType) {
        if (!roundActive || isDrawer || !mqttClient || gameEnded) return;
        if (itemType === 'egg') {
            if (eggCooldown) return;
            eggCooldown = true;
            const btn = document.getElementById('btn-egg');
            btn.classList.add('cooldown'); btn.textContent = '🍆 Recarregando...';
            mqttClient.publish(baseTopic + "/interact", JSON.stringify({ thrower: username, target: currentDrawerName, type: 'egg' }));
            setTimeout(() => { eggCooldown = false; btn.classList.remove('cooldown'); btn.textContent = '🍆 Jogar Berinjela!'; }, 8000);
        } else if (itemType === 'flower') {
            if (flowerCooldown) return;
            flowerCooldown = true;
            const btn = document.getElementById('btn-flower');
            btn.classList.add('cooldown'); btn.textContent = '🍑 Respirando...';
            mqttClient.publish(baseTopic + "/interact", JSON.stringify({ thrower: username, target: currentDrawerName, type: 'flower' }));
            setTimeout(() => { flowerCooldown = false; btn.classList.remove('cooldown'); btn.textContent = '🍑 Dar Sarrada!'; }, 5000);
        }
    }

    function animateInteractThrow(thrower, target, type) {
        const throwerEl = document.getElementById("p-" + thrower.replace(/\s+/g,'-'));
        const canvasRect = canvas.getBoundingClientRect();
        let sx = window.innerWidth / 2, sy = window.innerHeight - 100;
        if (throwerEl) { const r = throwerEl.getBoundingClientRect(); sx = r.left + r.width/2; sy = r.top + r.height/2; }
        const targetX = canvasRect.left + canvasRect.width/2 + (Math.random()-0.5)*120;
        const targetY = canvasRect.top + canvasRect.height/2 + (Math.random()-0.5)*100;
        const element = document.createElement('div');
        element.className = type === 'egg' ? 'egg-fly' : 'flower-fly';
        element.textContent = type === 'egg' ? '🍆' : '🍑';
        const dx = targetX - sx, dy = targetY - sy;
        const dist = Math.sqrt(dx*dx + dy*dy);
        const duration = Math.max(0.5, Math.min(1.0, dist/900));
        const angle = Math.atan2(dy, dx) * (180/Math.PI) + 90;
        element.style.setProperty('--tx', dx*0.75+'px'); element.style.setProperty('--ty', dy*0.75+'px');
        element.style.setProperty('--tx2', dx+'px'); element.style.setProperty('--rot', angle+'deg'); element.style.setProperty('--duration', duration+'s');
        element.style.left = sx+'px'; element.style.top = sy+'px';
        document.body.appendChild(element);
        setTimeout(() => {
            element.remove();
            const splash = document.createElement('div');
            splash.className = type === 'egg' ? 'egg-splash' : 'flower-splash';
            splash.textContent = type === 'egg' ? '💦' : '💥';
            splash.style.left = (targetX-24)+'px'; splash.style.top = (targetY-24)+'px';
            document.body.appendChild(splash);
            setTimeout(() => splash.remove(), 900);
            if (target === username) {
                if (type === 'egg') {
                    const overlay = document.getElementById('egg-overlay');
                    overlay.classList.remove('splat'); void overlay.offsetWidth; overlay.classList.add('splat');
                    document.getElementById('canvas-container').classList.add('shake');
                    setTimeout(() => document.getElementById('canvas-container').classList.remove('shake'), 500);
                } else if (type === 'flower') { createPetalShower(); }
            }
        }, duration * 1000);
    }

    function createPetalShower() {
        for (let i = 0; i < 15; i++) {
            setTimeout(() => {
                const petal = document.createElement('div');
                petal.className = 'petal-particle';
                petal.textContent = ['💋','❤️','🔥'][Math.floor(Math.random() * 3)];
                petal.style.left = Math.random() * window.innerWidth + 'px';
                petal.style.setProperty('--drift', (Math.random() * 160 - 80) + 'px');
                petal.style.setProperty('--fall-duration', (Math.random() * 1.5 + 1.5) + 's');
                document.body.appendChild(petal);
                setTimeout(() => petal.remove(), 3000);
            }, i * 100);
        }
    }

    function skipRound() {
        if (!roundActive || !isDrawer || !mqttClient || gameEnded) return;
        mqttClient.publish(baseTopic + "/gameflow/skip", JSON.stringify({ drawer: username, word: currentWord }));
    }

    function connectToGame() {
        username = document.getElementById('input-username').value.trim();
        roomName = document.getElementById('input-room').value.trim().toLowerCase().replace(/[^a-z0-9]/g,"");
        const customInput = document.getElementById('input-custom-words').value.trim();
        if (!username || !roomName) { alert("Digita o seu nome e o nome do motel pra sincronizar!"); return; }
        if (customInput) { customWords = customInput.split(',').map(w => w.trim()).filter(w => w.length > 0); }
        document.getElementById('login-screen').style.display = 'none';
        document.getElementById('room-id').innerText = "Motel: " + roomName;
        adicionarJogadorLista(username);
        initMqtt();
    }

    function initMqtt() {
        baseTopic = "gartic_clone_free_2026/" + roomName;
        mqttClient = mqtt.connect('wss://broker.hivemq.com:8884/mqtt');
        mqttClient.on('connect', async () => {
            mqttClient.subscribe(baseTopic + "/chat");
            mqttClient.subscribe(baseTopic + "/draw");
            mqttClient.subscribe(baseTopic + "/presence");
            mqttClient.subscribe(baseTopic + "/presence/echo");
            mqttClient.subscribe(baseTopic + "/gameflow");
            mqttClient.subscribe(baseTopic + "/gameflow/skip");
            mqttClient.subscribe(baseTopic + "/scores");
            mqttClient.subscribe(baseTopic + "/interact");
            mqttClient.subscribe(baseTopic + "/customwords");
            mqttClient.subscribe(baseTopic + "/customwords/add");
            
            const identityPayload = JSON.stringify({ sender: "Sistema", text: `📢 ${username} deitou na cama da sala.`, name: username, type: "system" });
            mqttClient.publish(baseTopic + "/chat", identityPayload);
            mqttClient.publish(baseTopic + "/presence", identityPayload);
            
            await carregarPalavrasSalvas();
            if (customWords.length > 0) { mqttClient.publish(baseTopic + "/customwords", JSON.stringify({ words: customWords, sender: username })); }
            setTimeout(() => { checkAndAutoStart(); }, 2000);
        });

        mqttClient.on('message', (topic, message) => {
            const data = JSON.parse(message.toString());
            
            if (topic === baseTopic + "/chat") {
                if (data.type === "system") {
                    addSystemMessage(data.text);
                    if (data.name) { adicionarJogadorLista(data.name); checkAndAutoStart(); }
                } else if (data.type === "guess") {
                    if (data.isCorrect) {
                        addSuccessMessage(data.sender, data.text);
                        const pts = data.pts || 5;
                        addScore(data.sender, pts); showScorePopup(pts, data.sender);
                        if (currentDrawerName) { const dp = Math.max(1, Math.round(pts * 0.5)); addScore(currentDrawerName, dp); showScorePopup(dp, currentDrawerName); }
                        broadcastScores();
                        
                        if (checkEndGameConditions()) return;
                        
                        showGarticAnnouncement("🎯 EN CAI XOU!", `${data.sender} adivinhou o fetiche secreto: ${currentWord.toUpperCase()}!`);
                        handleRoundEndAutomatically();
                    } else { renderWrongGuessMessage(data.sender, data.text); }
                } else if (data.type === "talk") { renderNormalMessage(data.sender, data.text); }
            } else if (topic === baseTopic + "/draw" && !isDrawer && !gameEnded) {
                renderRemoteDraw(data);
            } else if (topic === baseTopic + "/presence") {
                if (data.name && data.name !== username) {
                    adicionarJogadorLista(data.name);
                    mqttClient.publish(baseTopic + "/presence/echo", JSON.stringify({ name: username }));
                    if (customWords.length > 0) { mqttClient.publish(baseTopic + "/customwords", JSON.stringify({ words: customWords, sender: username })); }
                    checkAndAutoStart();
                }
            } else if (topic === baseTopic + "/presence/echo") {
                if (data.name && data.name !== username) { adicionarJogadorLista(data.name); checkAndAutoStart(); }
            } else if (topic === baseTopic + "/gameflow" && !gameEnded) {
                handleGameFlow(data);
            } else if (topic === baseTopic + "/gameflow/skip" && !gameEnded) {
                showGarticAnnouncement("⏭️ BROCHOU!", `${data.drawer} não deu conta e passou a vez! A palavra era: ${data.word.toUpperCase()}`);
                addSystemMessage(`⏭️ Voltou pra trás: ${data.drawer}. O fetiche era: ${data.word.toUpperCase()}`);
                handleRoundEndAutomatically();
            } else if (topic === baseTopic + "/scores") {
                if (data.scores) { 
                    for (const [n,p] of Object.entries(data.scores)) { 
                        if (n !== username) { scores[n]=p; } 
                    } 
                    renderScoreboard(); 
                    checkEndGameConditions();
                }
            } else if (topic === baseTopic + "/interact") {
                animateInteractThrow(data.thrower, data.target, data.type);
                if (data.type === 'egg') addEggMessage(data.thrower, data.target);
                else if (data.type === 'flower') addFlowerMessage(data.thrower, data.target);
            } else if (topic === baseTopic + "/customwords") {
                if (data.words && data.words.length > 0 && customWords.length === 0) {
                    customWords = data.words;
                    addSystemMessage(`📝 Dicionário proibido de ${data.sender} injetado! (${data.words.length})`);
                    salvarPalavras();
                }
            } else if (topic === baseTopic + "/customwords/add") {
                if (data.words && data.words.length > 0) {
                    data.words.forEach(w => { if(!customWords.includes(w)) customWords.push(w); });
                    addSystemMessage(`📝 ${data.sender} colocou mais +${data.words.length} fantasias quentes na lista da rodada!`);
                    salvarPalavras();
                }
            }
        });
    }

    function broadcastScores() {
        if (!mqttClient) return;
        mqttClient.publish(baseTopic + "/scores", JSON.stringify({ scores }));
    }

    function checkAndAutoStart() {
        if (!roundActive && currentDrawerName === "" && listaJogadores.size > 0 && !gameEnded) {
            const arr = Array.from(listaJogadores);
            if (arr[0] === username) { drawNewRound(); }
        }
    }

    function drawNewRound() {
        if (!mqttClient || gameEnded) return;
        const arr = Array.from(listaJogadores); if (arr.length === 0) return;
        currentDrawerIndex = (currentDrawerIndex + 1) % arr.length;
        const nextDrawer = arr[currentDrawerIndex];
        const lista = getPalavras();
        const randomWord = lista[Math.floor(Math.random() * lista.length)];
        mqttClient.publish(baseTopic + "/gameflow", JSON.stringify({ drawer: nextDrawer, word: randomWord, currentIndex: currentDrawerIndex }));
    }

    function handleGameFlow(data) {
        if (gameEnded) return;
        clearInterval(countdownInterval); clearTimeout(nextRoundTimeout);
        currentDrawerName = data.drawer; currentWord = data.word; currentDrawerIndex = data.currentIndex;
        roundActive = true; currentTimeLeft = TEMPO_RODADA;
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        renderScoreboard();
        const eggBtn = document.getElementById('btn-egg');
        const flowerBtn = document.getElementById('btn-flower');
        const skipBtn = document.getElementById('btn-skip');
        if (currentDrawerName === username) {
            isDrawer = true; eggBtn.style.display = 'none'; flowerBtn.style.display = 'none';
            skipBtn.style.display = 'inline-flex';
            document.getElementById('word-display').innerText = "✏️ Seu fetiche secreto: " + currentWord.toUpperCase();
            addSystemMessage(`✏️ É a sua vez na cama! Desenhe: ${currentWord.toUpperCase()}`);
        } else {
            isDrawer = false; skipBtn.style.display = 'none';
            eggBtn.style.display = 'inline-flex'; eggBtn.classList.remove('cooldown'); eggBtn.textContent = '🍆 Jogar Berinjela!';
            flowerBtn.style.display = 'inline-flex'; flowerBtn.classList.remove('cooldown'); flowerBtn.textContent = '🍑 Dar Sarrada!';
            const u = "_ ".repeat(currentWord.length).trim();
            document.getElementById('word-display').innerText = `🎨 Esfregando pincel: ${currentDrawerName} (${u})`;
            addSystemMessage(`🎨 ${currentDrawerName} está rebolando no traço...`);
        }
        startLocalTimer(TEMPO_RODADA);
    }

    function startLocalTimer(seconds) {
        if (gameEnded) return;
        currentTimeLeft = seconds;
        document.getElementById('timer-display').innerText = "⏱️ Clímax: " + currentTimeLeft + "s";
        countdownInterval = setInterval(() => {
            if (gameEnded) { clearInterval(countdownInterval); return; }
            currentTimeLeft--;
            if (currentTimeLeft <= 0) {
                clearInterval(countdownInterval);
                document.getElementById('timer-display').innerText = "⏱️ Clímax: 0s";
                addSystemMessage(`🛑 Deu ruim! Tempo esgotado. A palavra oculta era: ${currentWord.toUpperCase()}`);
                showGarticAnnouncement("⏳ BROCHOU GERAL!", `Ninguém conseguiu desvendar o mistério! Era: ${currentWord.toUpperCase()}`);
                document.getElementById('btn-egg').style.display = 'none';
                document.getElementById('btn-flower').style.display = 'none';
                document.getElementById('btn-skip').style.display = 'none';
                handleRoundEndAutomatically();
            } else {
                document.getElementById('timer-display').innerText = "⏱️ Clímax: " + currentTimeLeft + "s";
            }
        }, 1000);
    }

    function handleRoundEndAutomatically() {
        roundActive = false; clearInterval(countdownInterval);
        document.getElementById('btn-egg').style.display = 'none';
        document.getElementById('btn-flower').style.display = 'none';
        document.getElementById('btn-skip').style.display = 'none';
        if (gameEnded) return;
        if (currentDrawerName === username) { nextRoundTimeout = setTimeout(() => { if (!gameEnded) drawNewRound(); }, 4000); }
    }

    function adicionarJogadorLista(nome) {
        if (listaJogadores.has(nome)) return;
        listaJogadores.add(nome); if (!scores[nome]) scores[nome] = 0;
        renderScoreboard();
    }

    function sendDrawData(action, x, y, color, size, shapeType = '', endX = 0, endY = 0) {
        if (!mqttClient || !roundActive || gameEnded) return;
        mqttClient.publish(baseTopic + "/draw", JSON.stringify({ action, x, y, color, size, shapeType, endX, endY }));
    }

    function sendClear() {
        if (!isDrawer || gameEnded) return;
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        if (mqttClient) mqttClient.publish(baseTopic + "/draw", JSON.stringify({ action: 'clear' }));
    }

    function sendGuessMessage() {
        const input = document.getElementById('guess-input'); const msgText = input.value.trim();
        if (!msgText || !mqttClient || gameEnded) return;
        if (!roundActive || isDrawer) { input.value = ""; return; }
        const palpiteLimpo = msgText.toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g,"");
        const respostaLimpa = currentWord.toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g,"");
        if (palpiteLimpo === respostaLimpa) {
            const pts = calcPoints(currentTimeLeft);
            mqttClient.publish(baseTopic + "/chat", JSON.stringify({ sender: username, text: `Gemeu certinho: ${currentWord.toUpperCase()}! 🎯`, isCorrect: true, pts, type: "guess" }));
        } else {
            mqttClient.publish(baseTopic + "/chat", JSON.stringify({ sender: username, text: msgText, isCorrect: false, type: "guess" }));
        }
        input.value = "";
    }

    function sendChatMessage() {
        const input = document.getElementById('chat-input'); const msgText = input.value.trim();
        if (!msgText || !mqttClient) return;
        mqttClient.publish(baseTopic + "/chat", JSON.stringify({ sender: username, text: msgText, type: "talk" }));
        input.value = "";
    }

    document.getElementById('guess-input').addEventListener('keypress', function(e) { if (e.key === 'Enter') sendGuessMessage(); });
    document.getElementById('chat-input').addEventListener('keypress', function(e) { if (e.key === 'Enter') sendChatMessage(); });

    function addSystemMessage(text) {
        const c = document.getElementById('guess-messages'); const m = document.createElement('div'); m.className = "msg msg-system"; m.innerText = text; c.appendChild(m); c.scrollTop = c.scrollHeight;
    }
    function addSuccessMessage(sender, text) {
        const c = document.getElementById('guess-messages'); const m = document.createElement('div'); m.className = "msg msg-success"; m.innerText = `🎯 ${sender} ${text}`; c.appendChild(m); c.scrollTop = c.scrollHeight;
        if (!gameEnded) document.getElementById('word-display').innerText = "🎉 No alvo! Preparando próxima rodada...";
    }
    function renderWrongGuessMessage(sender, text) {
        const c = document.getElementById('guess-messages'); const m = document.createElement('div'); m.className = "msg msg-wrong"; m.innerText = `${sender}: ${text}`; c.appendChild(m); c.scrollTop = m.scrollHeight;
    }
    function renderNormalMessage(sender, text) {
        const c = document.getElementById('chat-messages'); const m = document.createElement('div'); m.className = "msg msg-normal"; const s = document.createElement('span'); s.className = "username"; s.innerText = sender + ": ";
        m.appendChild(s); m.appendChild(document.createTextNode(text)); c.appendChild(m); c.scrollTop = c.scrollHeight;
    }
    function addEggMessage(thrower, target) {
        const c = document.getElementById('chat-messages'); const m = document.createElement('div'); m.className = "msg msg-egg"; m.innerText = `🍆 ${thrower} atirou uma berinjela violenta em ${target}!`; c.appendChild(m); c.scrollTop = c.scrollHeight;
    }
    function addFlowerMessage(thrower, target) {
        const c = document.getElementById('chat-messages'); const m = document.createElement('div'); m.className = "msg msg-flower"; m.innerText = `🍑 ${thrower} encaixou uma sarrada de apoio em ${target}!`; c.appendChild(m); c.scrollTop = c.scrollHeight;
    }

    setActiveColor('#000000');
</script>
</body>
