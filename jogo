<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Gartic Proibidão Realtime</title>
    <script src="https://unpkg.com/mqtt/dist/mqtt.min.js"></script>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }

        body {
            background-color: #ff6b6b;
            display: flex; flex-direction: column; align-items: center;
            height: 100vh; height: -webkit-fill-available;
            padding: 8px; overscroll-behavior: none; overflow: hidden;
        }

        #login-screen {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: #ff6b6b; display: flex; justify-content: center;
            align-items: center; z-index: 1000;
        }
        .login-box {
            background: white; padding: 30px; border-radius: 15px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.2);
            width: 100%; max-width: 400px; text-align: center;
        }
        .login-box h2 { color: #e63946; margin-bottom: 20px; }
        .login-box input {
            width: 100%; padding: 12px; margin-bottom: 15px;
            border: 2px solid #ced4da; border-radius: 8px;
            outline: none; font-size: 16px;
        }
        .login-box input:focus { border-color: #e63946; }
        .login-box textarea {
            width: 100%; padding: 12px; margin-bottom: 15px;
            border: 2px solid #ced4da; border-radius: 8px;
            outline: none; font-size: 14px; resize: vertical;
            min-height: 70px; color: #333;
        }
        .login-box textarea:focus { border-color: #e63946; }
        .login-box .hint { font-size: 11px; color: #888; margin-top: -10px; margin-bottom: 15px; text-align: left; }

        header {
            text-align: center; margin-bottom: 6px; background: white;
            padding: 8px 16px; border-radius: 50px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
            width: 100%; max-width: 1400px;
            display: flex; justify-content: space-between; align-items: center;
            gap: 10px; flex-shrink: 0; position: relative;
        }
        h1 { color: #e63946; font-size: 20px; flex-shrink: 0; }
        #word-display {
            font-weight: bold; font-size: 16px; color: #d90429;
            background: #f8f9fa; padding: 4px 14px; border-radius: 20px;
            border: 2px dashed #d90429; text-align: center; word-break: break-word; flex: 1;
        }
        #room-display {
            font-weight: bold; color: #666; font-size: 12px;
            display: flex; flex-direction: column; align-items: flex-end;
            gap: 2px; flex-shrink: 0;
        }
        #timer-display { font-weight: bold; color: #d90429; font-size: 14px; }

        .btn-words-toggle {
            background: #e63946; color: white; border: none; padding: 6px 12px;
            border-radius: 20px; font-weight: bold; font-size: 12px; cursor: pointer;
            display: flex; align-items: center; gap: 4px; transition: background 0.2s;
        }
        .btn-words-toggle:hover { background: #b7094c; }
        #words-management-panel {
            position: absolute; top: 55px; left: 16px; background: white;
            padding: 12px; border-radius: 12px; box-shadow: 0 8px 24px rgba(0,0,0,0.2);
            border: 2px solid #e63946; z-index: 600; width: 280px; display: none;
            flex-direction: column; gap: 8px; text-align: left;
        }
        #words-management-panel label { font-size: 11px; font-weight: bold; color: #333; }
        #words-management-panel textarea {
            width: 100%; height: 60px; padding: 6px; font-size: 12px;
            border: 1px solid #ced4da; border-radius: 6px; resize: none; outline: none;
        }
        #words-management-panel textarea:focus { border-color: #e63946; }
        #words-management-panel .panel-actions { display: flex; justify-content: flex-end; gap: 6px; }

        #main-container {
            display: flex; width: 100%; max-width: 1400px;
            flex: 1; gap: 8px; overflow: hidden; min-height: 0;
        }

        #scoreboard {
            flex: 0 0 150px; background: white; border-radius: 12px; padding: 10px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
            display: flex; flex-direction: column; overflow: hidden;
        }
        #scoreboard h3 { color: #555; padding-bottom: 5px; border-bottom: 2px solid #f1f3f5; font-size: 14px; }
        #players-list {
            margin-top: 8px; overflow-y: auto; flex: 1;
            display: flex; flex-direction: column; gap: 5px;
        }
        .player-item {
            background: #f8f9fa; padding: 7px 8px; border-radius: 6px;
            font-weight: bold; color: #333; font-size: 11px;
            border-left: 4px solid #e63946;
            display: flex; justify-content: space-between; align-items: center;
        }
        .player-item.drawing { border-left-color: #d90429; background: #ffe3e8; }
        .player-info { display: flex; flex-direction: column; gap: 1px; overflow: hidden; }
        .player-rank { font-size: 9px; color: #777; font-weight: normal; }
        .player-name { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .player-score {
            background: #e63946; color: white; border-radius: 10px;
            padding: 1px 7px; font-size: 11px; font-weight: bold;
            min-width: 32px; text-align: center;
            transition: transform 0.2s, background 0.3s;
            flex-shrink: 0;
        }
        .player-item.drawing .player-score { background: #d90429; }
        .player-score.bump { transform: scale(1.4); background: #38b000 !important; }

        .score-popup {
            position: fixed; pointer-events: none;
            font-size: 20px; font-weight: bold; color: #38b000;
            text-shadow: 0 2px 6px rgba(0,0,0,0.25);
            animation: floatUp 1.4s ease-out forwards; z-index: 9999;
        }
        @keyframes floatUp {
            0%   { opacity: 1; transform: translateY(0) scale(1); }
            60%  { opacity: 1; transform: translateY(-40px) scale(1.15); }
            100% { opacity: 0; transform: translateY(-70px) scale(0.9); }
        }

        #canvas-container {
            flex: 1; background: white; border-radius: 12px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
            display: flex; flex-direction: column; overflow: hidden; position: relative;
            min-width: 0;
        }
        canvas {
            flex: 1; background: #ffffff; cursor: crosshair;
            touch-action: none;
            width: 100%; height: 100%; display: block;
            -webkit-user-select: none; user-select: none;
        }
        canvas.cursor-eraser { cursor: cell; }
        canvas.cursor-fill   { cursor: copy; }

        #round-announcement {
            position: absolute; top: 35%; left: 50%; transform: translate(-50%, -50%) scale(0.5);
            background: rgba(32, 10, 15, 0.95); color: white;
            padding: 18px 30px; border-radius: 16px; font-weight: bold; text-align: center;
            box-shadow: 0 8px 32px rgba(0,0,0,0.4); border: 3px solid #ff6b6b;
            z-index: 500; pointer-events: none; display: none; opacity: 0;
            transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            max-width: 85%; width: max-content;
        }
        #round-announcement.show { display: block; opacity: 1; transform: translate(-50%, -50%) scale(1); }
        #round-announcement h2 { font-size: 22px; color: #ff6b6b; margin-bottom: 4px; }
        #round-announcement p { font-size: 14px; color: #e6e6e6; font-weight: normal; }

        #tools {
            background: #200a0f;
            display: flex; flex-direction: column;
            padding: 8px; gap: 6px;
            border-right: 3px solid #ff6b6b;
            flex-shrink: 0; overflow-y: auto;
            width: 56px;
        }

        .tool-section-label {
            font-size: 8px; color: #aa888f; text-transform: uppercase;
            letter-spacing: 0.5px; text-align: center; margin-top: 2px;
        }

        .tool-btn {
            width: 38px; height: 38px; border-radius: 8px;
            border: 2px solid transparent; cursor: pointer;
            display: flex; align-items: center; justify-content: center;
            font-size: 16px; background: #3d1921;
            color: white; transition: all 0.15s;
            flex-shrink: 0;
            -webkit-tap-highlight-color: transparent;
        }
        .tool-btn:hover { background: #5a2833; border-color: #ff6b6b; }
        .tool-btn.active { background: #ff6b6b; color: #200a0f; border-color: #d90429; }

        .brush-sizes {
            display: flex; flex-direction: column; gap: 4px; align-items: center;
        }
        .size-btn {
            cursor: pointer; border-radius: 50%; background: white;
            border: 2px solid #555; transition: border-color 0.15s, transform 0.1s;
            flex-shrink: 0;
            -webkit-tap-highlight-color: transparent;
        }
        .size-btn:hover { border-color: #ff6b6b; transform: scale(1.15); }
        .size-btn.active { border-color: #ff6b6b; box-shadow: 0 0 0 2px rgba(255,107,107,0.5); }

        .tool-separator { height: 1px; background: #55242f; margin: 3px 0; }

        #palette-container {
            flex: 0 0 46px; background: #200a0f; border-radius: 12px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
            display: flex; flex-direction: column; overflow: hidden;
            padding: 6px 4px; gap: 4px;
        }
        #palette-label { font-size: 8px; color: #aa888f; text-transform: uppercase; letter-spacing: 0.5px; text-align: center; }
        #palette-grid {
            display: grid; grid-template-columns: repeat(2, 1fr);
            gap: 4px; overflow-y: auto; flex: 1;
        }
        #palette-grid::-webkit-scrollbar { width: 3px; }
        #palette-grid::-webkit-scrollbar-track { background: transparent; }
        #palette-grid::-webkit-scrollbar-thumb { background: #55242f; border-radius: 2px; }

        .color-swatch {
            width: 18px; height: 18px; border-radius: 4px;
            cursor: pointer; border: 2px solid transparent;
            transition: transform 0.1s, border-color 0.1s;
            flex-shrink: 0;
            -webkit-tap-highlight-color: transparent;
        }
        .color-swatch:hover { transform: scale(1.2); border-color: white; }
        .color-swatch.active { border-color: white; transform: scale(1.15); box-shadow: 0 0 0 1px #ff6b6b; }

        #color-custom { width: 100%; height: 22px; border: none; border-radius: 4px; cursor: pointer; padding: 0; flex-shrink: 0; }
        #current-color-display {
            width: 36px; height: 36px; border-radius: 8px;
            border: 3px solid white; flex-shrink: 0;
            box-shadow: 0 2px 6px rgba(0,0,0,0.3); align-self: center;
        }

        #bottom-actions {
            display: flex; gap: 6px; padding: 4px 8px;
            background: #200a0f; border-top: 2px solid #3d1921;
            align-items: center; flex-shrink: 0;
        }
        .btn { padding: 6px 12px; border: none; border-radius: 6px; cursor: pointer; font-weight: bold; font-size: 12px; flex-shrink: 0; -webkit-tap-highlight-color: transparent; }
        .btn-clear { background: #d90429; color: white; }
        .btn-skip { background: #f4a261; color: white; display: none; }
        
        .action-interact-btn {
            color: white; font-size: 13px; padding: 5px 10px; border-radius: 7px; border: none; cursor: pointer; font-weight: bold; flex-shrink: 0; display: none; transition: transform 0.1s, background 0.2s; box-shadow: 0 3px 8px rgba(0,0,0,0.15);
            -webkit-tap-highlight-color: transparent;
        }
        #btn-egg { background: #7209b7; }
        #btn-egg:active { transform: scale(0.92); background: #560bad; }
        #btn-flower { background: #f72585; }
        #btn-flower:active { transform: scale(0.92); background: #b5179e; }
        .action-interact-btn.cooldown { opacity: 0.4; cursor: not-allowed; pointer-events: none; }

        .egg-fly, .flower-fly {
            position: fixed; font-size: 36px; pointer-events: none; z-index: 9999;
            animation: itemFly var(--duration, 0.9s) cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
        }
        @keyframes itemFly {
            0%   { opacity: 1; transform: translate(0,0) rotate(0deg) scale(1); }
            70%  { opacity: 1; transform: translate(var(--tx), var(--ty)) rotate(var(--rot)) scale(1.1); }
            85%  { opacity: 1; transform: translate(var(--tx2), var(--ty2)) rotate(var(--rot)) scale(1.3); }
            100% { opacity: 0; transform: translate(var(--tx2), var(--ty2)) rotate(var(--rot)) scale(0.5); }
        }
        .egg-splash, .flower-splash { position: fixed; font-size: 48px; pointer-events: none; z-index: 9999; animation: itemSplash 0.8s ease-out forwards; }
        @keyframes itemSplash {
            0%   { opacity: 1; transform: scale(0.5); }
            40%  { opacity: 1; transform: scale(1.6); }
            100% { opacity: 0; transform: scale(2.2); }
        }
        @keyframes screenShake {
            0%  { transform: translate(0,0); }
            15% { transform: translate(-6px, 3px); }
            30% { transform: translate(6px, -3px); }
            45% { transform: translate(-4px, 4px); }
            60% { transform: translate(4px, -2px); }
            75% { transform: translate(-2px, 2px); }
            100%{ transform: translate(0,0); }
        }
        .shake { animation: screenShake 0.45s ease; }
        #egg-overlay { position: fixed; inset: 0; pointer-events: none; background: rgba(114, 9, 183, 0.35); opacity: 0; z-index: 9998; transition: opacity 0.1s; }
        #egg-overlay.splat { animation: splatFade 1.2s ease-out forwards; }
        @keyframes splatFade { 0% { opacity: 0.7; } 100% { opacity: 0; } }
        .petal-particle { position: fixed; pointer-events: none; font-size: 18px; z-index: 9997; animation: petalFall var(--fall-duration, 2s) linear forwards; }
        @keyframes petalFall {
            0% { transform: translateY(-20px) translateX(0) rotate(0deg); opacity: 1; }
            100% { transform: translateY(105vh) translateX(var(--drift, 50px)) rotate(360deg); opacity: 0; }
        }

        #right-chats-wrapper {
            flex: 0 0 240px; display: flex; flex-direction: column; gap: 8px; overflow: hidden;
        }
        .chat-box-container {
            flex: 1; background: white; border-radius: 12px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
            display: flex; flex-direction: column; overflow: hidden;
        }
        .chat-title-bar { background: #200a0f; color: white; padding: 4px 8px; font-size: 11px; font-weight: bold; text-transform: uppercase; display: flex; align-items: center; gap: 4px; flex-shrink: 0; }
        .chat-messages-area { flex: 1; padding: 8px; overflow-y: auto; display: flex; flex-direction: column; gap: 4px; }
        .msg { padding: 4px 6px; border-radius: 5px; font-size: 11px; word-break: break-all; line-height: 1.3; }
        .msg-system  { background: #fae0e4; color: #7209b7; font-weight: bold; }
        .msg-success { background: #d1e7dd; color: #0f5132; font-weight: bold; border: 1px solid #badbcc; }
        .msg-wrong   { background: #ffe3e8; color: #c92a2a; }
        .msg-normal  { background: #f1f3f5; color: #333; }
        .msg-normal .username { font-weight: bold; color: #e63946; }
        .msg-egg     { background: #f3e5f5; color: #4a148c; font-weight: bold; border: 1px solid #ce93d8; }
        .msg-flower  { background: #fce4ec; color: #880e4f; font-weight: bold; border: 1px solid #f48fb1; }
        .chat-input-row { display: flex; padding: 5px; border-top: 1px solid #dee2e6; background: #f8f9fa; flex-shrink: 0; }
        .chat-input-field { flex: 1; padding: 6px; border: 2px solid #ced4da; border-radius: 5px; outline: none; font-size: 12px; }
        .chat-send-btn { background: #e63946; color: white; margin-left: 4px; font-size: 11px; padding: 4px 8px; border: none; border-radius: 4px; cursor: pointer; font-weight: bold; }

        @media (max-width: 768px) {
            body { padding: 4px; overflow: hidden; }

            header {
                padding: 5px 8px; margin-bottom: 0;
                height: 44px; border-radius: 8px; flex-shrink: 0;
            }
            h1 { font-size: 11px; }
            #word-display { font-size: 10px; padding: 2px 6px; }
            #room-display { font-size: 9px; }
            #timer-display { font-size: 10px; }
            #words-management-panel { top: 48px; left: 4px; width: 260px; }

            #main-container {
                position: absolute;
                top: 52px;
                left: 4px;
                right: 4px;
                bottom: 4px;
                flex-direction: column;
                gap: 4px;
                overflow: hidden;
            }

            #scoreboard {
                flex: 0 0 36px !important;
                width: 100%;
                padding: 3px 6px;
                border-radius: 6px;
                flex-direction: row;
                align-items: center;
            }
            #scoreboard h3 { display: none; }
            #players-list {
                margin-top: 0;
                flex-direction: row !important;
                overflow-x: auto; overflow-y: hidden;
                height: 100%;
                align-items: center;
                gap: 5px;
            }
            .player-item {
                padding: 3px 6px; font-size: 10px;
                height: 28px; white-space: nowrap;
                display: inline-flex; flex-shrink: 0; align-items: center;
            }

            #canvas-wrapper {
                flex: 1 1 0 !important;
                min-height: 0 !important;
                display: flex !important;
                flex-direction: column !important;
            }

            #drawing-area {
                flex: 1 1 0 !important;
                min-height: 0 !important;
                display: flex !important;
                flex-direction: column !important;
            }

            #canvas-container {
                flex: 1 1 0 !important;
                min-height: 0 !important;
                position: relative !important;
                overflow: hidden !important;
            }

            #canvas {
                position: absolute !important;
                top: 0 !important; left: 0 !important;
                width: 100% !important;
                height: 100% !important;
            }

            #tools {
                width: 100%;
                flex-direction: row;
                overflow-x: auto; overflow-y: hidden;
                border-right: none;
                border-top: 2px solid #ff6b6b;
                height: 50px;
                min-height: 50px;
                padding: 6px 10px;
                align-items: center;
                gap: 8px;
                flex-shrink: 0 !important;
            }
            .tool-section-label { display: none; }
            .tool-separator { width: 1px; height: 32px; background: #55242f; margin: 0 2px; flex-shrink: 0; }
            .brush-sizes { flex-direction: row; gap: 6px; align-items: center; }
            .tool-btn { width: 38px; height: 38px; font-size: 17px; flex-shrink: 0; }
            .size-btn { flex-shrink: 0; }

            #palette-container {
                flex: 0 0 42px !important;
                width: 100% !important;
                height: 42px !important;
                flex-direction: row !important;
                padding: 5px 8px;
                gap: 6px;
                border-radius: 8px;
                align-items: center;
                flex-shrink: 0 !important;
            }
            #palette-label { display: none; }
            #palette-grid {
                grid-template-columns: repeat(14, 22px);
                overflow-x: auto; overflow-y: hidden;
                height: 28px;
                gap: 3px;
                flex: 1;
            }
            .color-swatch { width: 22px; height: 22px; border-radius: 4px; }
            #current-color-display { width: 28px; height: 28px; flex-shrink: 0; }
            #color-custom { width: 26px; height: 26px; border-radius: 4px; flex-shrink: 0; }

            #bottom-actions { padding: 3px 6px; flex-wrap: wrap; gap: 4px; }

            #right-chats-wrapper {
                flex: 0 0 150px !important;
                width: 100% !important;
                flex-direction: row !important;
                gap: 4px;
                flex-shrink: 0 !important;
            }
            .chat-box-container { flex: 1; min-width: 0; }
            .chat-messages-area { font-size: 10px; padding: 5px; }
            .chat-input-field { font-size: 11px; padding: 4px; }
        }

        #canvas-wrapper {
            flex: 1; display: flex; flex-direction: column; overflow: hidden; min-width: 0;
        }
        #drawing-area {
            flex: 1; display: flex; flex-direction: row; overflow: hidden; min-height: 0;
        }
        #canvas-container { flex: 1; position: relative; min-height: 0; }

        #fill-status {
            display: none;
            position: absolute; top: 8px; left: 50%; transform: translateX(-50%);
            background: rgba(0,0,0,0.7); color: white;
            padding: 4px 12px; border-radius: 20px; font-size: 12px; font-weight: bold;
            pointer-events: none; z-index: 10;
        }
    </style>
</head>
<body>

<div id="egg-overlay"></div>

<div id="login-screen">
    <div class="login-box">
        <h2>🌶️ Gartic Proibidão</h2>
        <input type="text" id="input-username" placeholder="👤 Seu Nome / Apelido Safado" required>
        <input type="text" id="input-room" placeholder="🔑 Nome do Motel / Sala" required>
        <textarea id="input-custom-words" placeholder="📝 Palavras personalizadas (opcional)&#10;Ex: Algema, Chicote, Melancia..."></textarea>
        <p class="hint">Separe por vírgula. Se deixar em branco, o sistema usa o nosso banco de dados picante da zueira.</p>
        <button class="btn" style="width:100%;padding:12px;font-size:16px;background:#e63946;color:white;" onclick="connectToGame()">🚀 ENTRAR NA SAFADEZA</button>
    </div>
</div>

<header>
    <h1>🌶️ PROIBIDÃO</h1>
    <button class="btn-words-toggle" onclick="toggleWordsPanel()">📝 Palavras</button>
    <div id="words-management-panel">
        <label>➕ Injetar Palavras na Sala:</label>
        <textarea id="runtime-new-words" placeholder="Ex: Cueca, Calcinha, Morango... (separe por vírgula)"></textarea>
        <div class="panel-actions">
            <button class="btn" style="background:#d90429; color:white; padding:4px 8px; font-size:11px;" onclick="toggleWordsPanel()">Fechar</button>
            <button class="btn" style="background:#38b000; color:white; padding:4px 8px; font-size:11px;" onclick="submitRuntimeWords()">Injetar</button>
        </div>
    </div>
    <div id="word-display">⏳ Esperando os safados entrarem...</div>
    <div id="room-display">
        <span id="room-id">Motel: —</span>
        <span id="timer-display">⏱️ Clímax: --</span>
    </div>
</header>

<div id="main-container">
    <div id="scoreboard">
        <h3>🏆 Atrevidos</h3>
        <div id="players-list"></div>
    </div>

    <div id="canvas-wrapper">
        <div id="drawing-area">
            <div id="tools">
                <span class="tool-section-label">Estilo</span>
                <div class="tool-btn active" id="tool-brush" title="Pincel Macio" onclick="setTool('brush')">✏️</div>
                <div class="tool-btn" id="tool-eraser" title="Apagar Evidências" onclick="setTool('eraser')">🧹</div>
                <div class="tool-btn" id="tool-fill" title="Arrombar Balde" onclick="setTool('fill')">🪣</div>

                <div class="tool-separator"></div>
                <span class="tool-section-label">Curvas</span>
                <div class="tool-btn active" id="shape-free" title="Movimento Livre" onclick="setShape('free')">〰️</div>
                <div class="tool-btn" id="shape-circle" title="Forma Redonda" onclick="setShape('circle')">⭕</div>
